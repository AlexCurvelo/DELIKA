:root {
  --roxo-delika: #6b2d8c;
  --roxo-escuro: #311440;
  --dourado: #d4af37;
  --lilas-claro: #f3e5f5;
  --fundo-site: #f4f6f8;
  --texto-base: #333333;
  --verde-sucesso: #25d366;
  --vermelho-erro: #ff6b6b;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: "Urbanist", sans-serif;
  color: var(--texto-base);
  background: var(--fundo-site);
  line-height: 1.5;
  display: flex;
  min-height: 100vh;
}
/* Sidebar ADM */
.sidebar {
  width: 260px;
  background: var(--roxo-escuro);
  color: #fff;
  display: flex;
  flex-direction: column;
  position: fixed;
  inset: 0 auto 0 0;
  box-shadow: 4px 0 16px rgba(0, 0, 0, 0.14);
  z-index: 1000;
}
.sidebar-header {
  padding: 26px 20px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  text-align: center;
}
.sidebar-header img {
  width: 94px;
  margin-bottom: 10px;
}
.sidebar-header h2 {
  font-family: "Playfair Display", serif;
  color: var(--dourado);
  font-size: 1.15rem;
  font-weight: 700;
}
.nav-menu {
  list-style: none;
  flex: 1;
  padding: 18px 0;
  overflow-y: auto;
}
.nav-menu a {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 22px;
  color: #d7d7d7;
  text-decoration: none;
  font-weight: 600;
  transition: background 0.2s ease, color 0.2s ease;
}
.nav-menu a:hover, .nav-menu a.ativo {
  background: rgba(255, 255, 255, 0.12);
  color: var(--dourado);
  border-left: 4px solid var(--dourado);
}
.nav-menu i {
  width: 18px;
  text-align: center;
}
.logout-btn {
  padding: 18px 22px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}
.logout-btn a {
  color: #ff8f8f;
  text-decoration: none;
  display: inline-flex;
  gap: 8px;
  align-items: center;
  font-weight: 700;
}
.logout-btn a:hover {
  color: #ff6d6d;
}
.main-content {
  margin-left: 260px;
  flex: 1;
  padding: 56px 64px 40px 64px;
  min-height: 100vh;
  background: var(--fundo-site);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  box-sizing: border-box;
}
.topbar {
  margin-bottom: 38px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}
.topbar h1 {
  font-family: "Playfair Display", serif;
  font-size: 2.2rem;
  color: var(--roxo-escuro);
  margin-bottom: 0;
}
.user-profile {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-weight: 600;
  color: var(--roxo-escuro);
  font-size: 1.05rem;
}
.user-profile i {
  color: var(--dourado);
  font-size: 1.35rem;
}
.main-content section {
  margin-top: 24px;
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  padding: 32px 28px;
  max-width: 900px;
  width: 100%;
}
@media (max-width: 860px) {
  .main-content {
    margin-left: 0;
    padding: 24px 8px 24px 8px;
  }
  .main-content section {
    padding: 18px 8px;
    max-width: 100%;
  }
  .topbar h1 {
    font-size: 1.3rem;
  }
}
.topbar {
  margin-bottom: 34px;
}
.topbar h1 {
  font-family: "Playfair Display", serif;
  font-size: 2rem;
  color: var(--roxo-escuro);
  margin-bottom: 8px;
}
.user-profile {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-weight: 600;
  color: var(--roxo-escuro);
  font-size: 0.96rem;
}
.user-profile i {
  color: var(--dourado);
  font-size: 1.2rem;
}
.main-content section {
  margin-top: 18px;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Ficha Técnica Pro | Deliká ADM</title>
  <link rel="icon" href="../img/logodlk.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Urbanist:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="adm-style.css">
  <style>
    .recipe-builder { display: grid; grid-template-columns: 1fr 350px; gap: 30px; }
    .card { background: #fff; padding: 25px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
    .form-group { margin-bottom: 15px; }
    label { font-weight: 700; font-size: 0.85rem; color: #555; display: block; margin-bottom: 5px; }
    select, input { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; font-family: inherit; }
    .ingrediente-row { display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 10px; align-items: flex-end; margin-bottom: 10px; padding-bottom: 10px; border-bottom: 1px dashed #eee; }
    .btn-add-ing { background: var(--roxo-delika); color: #fff; border: none; padding: 10px; border-radius: 8px; cursor: pointer; width: 100%; font-weight: 700; }
    .total-box { background: var(--roxo-escuro); color: var(--dourado); padding: 20px; border-radius: 12px; text-align: center; margin-top: 20px; }
    .total-box h4 { color: #fff; opacity: 0.8; font-size: 0.8rem; text-transform: uppercase; }
    .total-box p { font-size: 2rem; font-weight: 900; }
    .btn-save-recipe { background: var(--verde-sucesso); color: #fff; border: none; padding: 15px; border-radius: 10px; width: 100%; font-weight: 700; cursor: pointer; margin-top: 15px; font-size: 1rem; }
    .recipe-list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid #eee; }
    .recipe-list-item strong { color: var(--roxo-delika); }
  </style>
</head>
<body>

  <aside class="sidebar">
    <div class="sidebar-header">
    <img src="../img/logodlk.png" alt="Deliká">
      <h2>Painel ADM</h2>
    </div>
    <ul class="nav-menu">
    <li><a href="painel.html"><i class="fa-solid fa-chart-pie"></i> Visão Geral</a></li>
      <li><a href="pedidos.html"><i class="fa-solid fa-list-check"></i> Pedidos</a></li>
      <li><a href="produtos.html"><i class="fa-solid fa-cake-candles"></i> Meus Bolos</a></li>
      <li><a href="clientes.html"><i class="fa-solid fa-users"></i> Clientes</a></li>
      <li><a href="estoque.html"><i class="fa-solid fa-boxes-stacked"></i> Estoque</a></li>
      <li><a href="custos.html" class="ativo"><i class="fa-solid fa-coins"></i> Custos</a></li>
    </ul>
  </aside>

  <main class="main-content">
    <div style="margin-bottom: 30px;">
        <h1>Calculadora de Ficha Técnica</h1>
        <p>Monte as receitas e calcule o custo real de produção baseado no estoque.</p>
    </div>

    <div class="recipe-builder">
      <div class="card">
        <h3 style="font-family:'Playfair Display'; margin-bottom: 20px;">Nova Receita</h3>
        <div class="form-group">
            <label>Nome do Produto Final</label>
            <input type="text" id="recipeName" placeholder="Ex: Bolo de FubÃ¡ com Goiabada">
        </div>

        <div id="ingredientesContainer">
            <!-- Linhas de ingredientes entram aqui -->
        </div>

        <button class="btn-add-ing" onclick="addIngredienteRow()"><i class="fa-solid fa-plus"></i> Adicionar Ingrediente</button>
      </div>

      <div class="sidebar-calc">
        <div class="card">
            <h3 style="font-family:'Playfair Display'; margin-bottom: 15px;">Resumo Financeiro</h3>
            <div class="total-box">
                <h4>Custo de ProduÃ§Ã£o</h4>
                <p id="displayCustoTotal">R$ 0,00</p>
            </div>
            <div class="form-group" style="margin-top: 20px;">
                <label>Margem de Lucro Sugerida (%)</label>
                <input type="number" id="lucroDesejado" value="100" oninput="calcularSugestao()">
            </div>
            <div style="margin-top: 15px; font-weight: 700; color: #444;">
                SugestÃ£o de Venda: <span id="displaySugestao" style="color:var(--verde-sucesso)">R$ 0,00</span>
            </div>
            <button class="btn-save-recipe" onclick="salvarReceitaCompleta()">Finalizar e Guardar Receita</button>
        </div>

        <div class="card" style="margin-top: 20px;">
            <h3 style="font-size: 1rem; margin-bottom: 10px;">Receitas Guardadas</h3>
            <div id="listaReceitasSalvas"></div>
        </div>
      </div>
    </div>
  </main>

  <script src="adm-auth.js"></script>
  <script>
    const CONVERSOES = {
        'unid': 1, 'kg': 1, 'lt': 1, 'g': 0.001, 'ml': 0.001,
        'xicara': 0.250, 'meia_xicara': 0.125, 'terco_xicara': 0.083, 'quarto_xicara': 0.062,
        'sopa': 0.015, 'cha': 0.005, 'cafe': 0.002
    };

    let estoque = JSON.parse(localStorage.getItem("delika_inventory_v5")) || [];
    let receitas = JSON.parse(localStorage.getItem("delika_recipes_v5")) || [];

    function addIngredienteRow() {
        const container = document.getElementById('ingredientesContainer');
        const div = document.createElement('div');
        div.className = 'ingrediente-row';
        let options = estoque.map(item => `<option value="${item.id}">${item.nome} (${item.unidade})</option>`).join('');
        div.innerHTML = `
            <div>
                <label>Ingrediente</label>
                <select class="ing-select" onchange="atualizarCustos()">
                    <option value="">Selecione...</option>
                    ${options}
                </select>
            </div>
            <div>
                <label>Medida</label>
                <select class="ing-medida" onchange="atualizarCustos()">
                    <option value="kg">kg / lt / unid</option>
                    <option value="g">gramas (g)</option>
                    <option value="ml">mililitros (ml)</option>
                    <option value="xicara">1 Xícara (250ml)</option>
                    <option value="meia_xicara">1/2 Xícara</option>
                    <option value="sopa">1 Colher Sopa</option>
                    <option value="cha">1 Colher Chá</option>
                </select>
            </div>
            <div>
                <label>Qtd.</label>
                <input type="number" class="ing-qtd" value="1" step="0.1" oninput="atualizarCustos()">
            </div>
            <button class="btn-delete" onclick="this.parentElement.remove(); atualizarCustos();" style="color:red; border:none; background:none; cursor:pointer; font-size:1.2rem; padding-bottom:12px"><i class="fa-solid fa-trash"></i></button>
        `;
        container.appendChild(div);
    }

    function atualizarCustos() {
        let total = 0;
        const rows = document.querySelectorAll('.ingrediente-row');
        rows.forEach(row => {
            const id = row.querySelector('.ing-select').value;
            const medida = row.querySelector('.ing-medida').value;
            const qtd = parseFloat(row.querySelector('.ing-qtd').value) || 0;
            const itemEstoque = estoque.find(i => i.id == id);
            if (itemEstoque) {
                const fator = CONVERSOES[medida] || 1;
                total += (itemEstoque.preco * fator * qtd);
            }
        });
        document.getElementById('displayCustoTotal').textContent = `R$ ${isNaN(total) ? '0,00' : total.toFixed(2).replace('.', ',')}`;
        calcularSugestao();
    }

    function calcularSugestao() {
        const custo = parseFloat(document.getElementById('displayCustoTotal').textContent.replace('R$ ', '').replace(',', '.')) || 0;
        const margem = parseFloat(document.getElementById('lucroDesejado').value) / 100 || 0;
        const sugestao = custo + (custo * margem);
        document.getElementById('displaySugestao').textContent = `R$ ${isNaN(sugestao) ? '0,00' : sugestao.toFixed(2).replace('.', ',')}`;
    }

    function salvarReceitaCompleta() {
        const nome = document.getElementById('recipeName').value;
        if(!nome) return alert("Dê um nome à receita!");
        const ingredientes = [];
        document.querySelectorAll('.ingrediente-row').forEach(row => {
            ingredientes.push({
                insumoId: row.querySelector('.ing-select').value,
                medida: row.querySelector('.ing-medida').value,
                qtd: parseFloat(row.querySelector('.ing-qtd').value) || 0
            });
        });
        const novaReceita = {
            id: Date.now(),
            nome: nome,
            custo: parseFloat(document.getElementById('displayCustoTotal').textContent.replace('R$ ', '').replace(',', '.')) || 0,
            itens: ingredientes
        };
        receitas.push(novaReceita);
        localStorage.setItem("delika_recipes_v5", JSON.stringify(receitas));
        renderReceitasSalvas();
        alert("Receita guardada com sucesso!");
    }

    function renderReceitasSalvas() {
        const list = document.getElementById('listaReceitasSalvas');
        list.innerHTML = receitas.map(r => `
            <div class="recipe-list-item">
                <span><strong>${r.nome}</strong> <br><small>Custo: R$ ${r.custo.toFixed(2).replace('.', ',')}</small></span>
                <button onclick="apagarReceita(${r.id})" style="border:none; background:none; color:red; cursor:pointer"><i class="fa-solid fa-xmark"></i></button>
            </div>
        `).join('');
    }

    window.apagarReceita = (id) => {
        receitas = receitas.filter(r => r.id !== id);
        localStorage.setItem("delika_recipes_v5", JSON.stringify(receitas));
        renderReceitasSalvas();
    }

    if (window.DelikAuth) window.DelikAuth.requireAuth();
    renderReceitasSalvas();
  </script>
</body>
</html>

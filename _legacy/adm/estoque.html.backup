<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex,nofollow">
  <title>Gestão de Insumos | Deliká ADM</title>
  <link rel="icon" href="../img/logodlk.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Urbanist:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="adm-style.css">
  <style>
    .header-summary { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 20px; flex-wrap: wrap; }
    .patrimonio-card { background: var(--roxo-escuro); color: var(--dourado); padding: 20px 30px; border-radius: 15px; font-weight: 700; box-shadow: 0 8px 20px rgba(0,0,0,0.1); }
    .patrimonio-card small { display: block; color: #fff; opacity: 0.7; font-size: 0.8rem; margin-bottom: 5px; }
    .table-container { background: #fff; border-radius: 14px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; text-align: left; min-width: 800px; }
    th, td { padding: 16px 20px; border-bottom: 1px solid #eee; }
    th { background: #fafafa; color: #666; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; }
    .unit-badge { background: #eee; padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 800; color: #666; }
    .btn-delete { color: var(--vermelho-erro); border: none; background: none; cursor: pointer; font-size: 1.1rem; }
    .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: none; place-items: center; z-index: 2000; padding: 20px; }
    .modal.active { display: grid; }
    .modal-content { background: #fff; padding: 30px; border-radius: 20px; width: 100%; max-width: 500px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px; }
    .full { grid-column: span 2; }
    label { font-size: 0.85rem; font-weight: 700; color: #555; display: block; margin-bottom: 5px; }
    input, select { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; font-family: inherit; outline: none; }
    input:focus { border-color: var(--roxo-delika); }
    .btn-save { background: var(--roxo-delika); color: #fff; border: none; padding: 15px; border-radius: 10px; width: 100%; font-weight: 700; cursor: pointer; margin-top: 20px; transition: 0.2s; }
    .btn-save:hover { background: var(--roxo-escuro); }
  </style>
</head>
<body>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <img src="../img/logodlk.png" alt="Deliká">
      <h2>Painel ADM</h2>
    </div>
    <ul class="nav-menu">
      <li class="menu-divisor">Principal</li>
      <li><a href="painel.html"><i class="fa-solid fa-chart-pie"></i> Visão Geral</a></li>
      <li><a href="pedidos.html"><i class="fa-solid fa-list-check"></i> Pedidos</a></li>
      <li><a href="produtos.html"><i class="fa-solid fa-cake-candles"></i> Meus Bolos</a></li>
      <li><a href="clientes.html"><i class="fa-solid fa-users"></i> Clientes</a></li>
      <li class="menu-divisor">Operação</li>
      <li><a href="estoque.html" class="ativo"><i class="fa-solid fa-boxes-stacked"></i> Estoque</a></li>
      <li><a href="custos.html"><i class="fa-solid fa-coins"></i> Custos</a></li>
    </ul>
    <div class="logout-btn">
        <a href="#" data-logout="true"><i class="fa-solid fa-right-from-bracket"></i> Sair</a>
    </div>
  </aside>

  <main class="main-content">
    <div class="header-summary">
      <h1>Controle de Insumos</h1>
      <div class="patrimonio-card">
        <small>PATRIMÔNIO TOTAL EM ESTOQUE</small>
        <span id="totalEstoqueValue">R$ 0,00</span>
      </div>
    </div>

    <button class="btn-action" onclick="toggleModal(true)" style="background: var(--dourado); color: var(--roxo-escuro); border: none; padding: 12px 20px; border-radius: 8px; font-weight: 700; cursor: pointer; margin-bottom: 20px;">
      <i class="fa-solid fa-plus"></i> Novo Insumo
    </button>

    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Insumo</th>
            <th>Unidade</th>
            <th>Preço Unit.</th>
            <th>Qtd. Estoque</th>
            <th>Subtotal</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="estoqueTableBody">
            <!-- Renderizado via JS -->
        </tbody>
      </table>
    </div>
  </main>

  <!-- MODAL CADASTRO INSUMO -->
  <div class="modal" id="insumoModal">
    <div class="modal-content">
      <h2 style="font-family:'Playfair Display'; color: var(--roxo-delika)">Novo Insumo</h2>
      <form id="insumoForm">
        <div class="form-grid">
          <div class="full">
            <label>Nome do Insumo</label>
            <input type="text" id="nome" placeholder="Ex: Açúcar Refinado" required>
          </div>
          <div>
            <label>Unidade</label>
            <select id="unidade">
              <option value="kg">kg (Quilo)</option>
              <option value="lt">lt (Litro)</option>
              <option value="g">g (Grama)</option>
              <option value="ml">ml (Mililitro)</option>
              <option value="unid">unid (Unidade)</option>
            </select>
          </div>
          <div>
            <label>Preço Unitário (R$)</label>
            <input type="number" id="preco" step="0.01" placeholder="4.50" required>
          </div>
          <div class="full">
            <label>Quantidade Atual (em unidades da medida acima)</label>
            <input type="number" id="quantidade" step="0.1" placeholder="Ex: 10" required>
          </div>
        </div>
        <button type="submit" class="btn-save">Salvar no InventÃ¡rio</button>
        <button type="button" onclick="toggleModal(false)" style="background:none; border:none; color:#888; width:100%; margin-top:10px; cursor:pointer">Cancelar</button>
      </form>
    </div>
  </div>

  <script src="adm-auth.js"></script>
  <script>
    (function() {
      "use strict";
      const STORAGE_KEY = "delika_inventory_v5";
      let estoque = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];

      window.toggleModal = function(show) {
        document.getElementById('insumoModal').classList.toggle('active', show);
      };

      function renderEstoque() {
        const tbody = document.getElementById('estoqueTableBody');
        const totalEl = document.getElementById('totalEstoqueValue');
        tbody.innerHTML = "";
        let valorTotalGeral = 0;

        if (estoque.length === 0) {
            tbody.innerHTML = "<tr><td colspan='6' style='text-align:center; padding: 40px; color: #999;'>Nenhum insumo cadastrado. Clique em 'Novo Insumo' para começar.</td></tr>";
        }

        estoque.forEach((item, index) => {
          const subtotal = item.preco * item.quantidade;
          valorTotalGeral += subtotal;

          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td><strong>${item.nome}</strong></td>
            <td><span class="unit-badge">${item.unidade}</span></td>
            <td>R$ ${parseFloat(item.preco).toFixed(2).replace('.', ',')}</td>
            <td>${item.quantidade}</td>
            <td><strong>R$ ${subtotal.toFixed(2).replace('.', ',')}</strong></td>
            <td>
              <button class="btn-delete" onclick="removerInsumo(${index})" title="Excluir"><i class="fa-solid fa-trash"></i></button>
            </td>
          `;
          tbody.appendChild(tr);
        });

        totalEl.textContent = `R$ ${valorTotalGeral.toFixed(2).replace('.', ',')}`;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(estoque));
      }

      document.getElementById('insumoForm').onsubmit = (e) => {
        e.preventDefault();
        const novo = {
          id: Date.now(),
          nome: document.getElementById('nome').value,
          unidade: document.getElementById('unidade').value,
          preco: parseFloat(document.getElementById('preco').value),
          quantidade: parseFloat(document.getElementById('quantidade').value)
        };
        estoque.push(novo);
        renderEstoque();
        toggleModal(false);
        e.target.reset();
      };

      window.removerInsumo = (i) => {
        if(confirm('Deseja realmente excluir este insumo do estoque?')) {
          estoque.splice(i, 1);
          renderEstoque();
        }
      };

      if (window.DelikAuth) window.DelikAuth.requireAuth();
      renderEstoque();
    })();
  </script>
</body>
</html>
